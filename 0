    async function refreshThemeCart() {
      const cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer) {
        if (typeof cartDrawer.renderContents === 'function') {
          try {
            const rootUrl = window.Shopify?.routes?.root || '/';
            const response = await fetch(`${rootUrl}?sections=cart-drawer,cart-icon-bubble`);
            if (!response.ok) {
              throw new Error(`Sections fetch failed: ${response.status}`);
            }
            const sections = await response.json();
            cartDrawer.renderContents(sections);
            return;
          } catch (err) {
            console.error('[Marvya Rewards] renderContents failed:', err);
          }
        }
        if (typeof cartDrawer.getSectionsToRender === 'function') {
          try {
            const sections = cartDrawer.getSectionsToRender();
            if (sections && Array.isArray(sections) && sections.length > 0) {
              const sectionIds = sections
                .map((s) => s.section)
                .filter(Boolean)
                .join(',');
              if (sectionIds) {
                const rootUrl = window.Shopify?.routes?.root || '/';
                const url = `${rootUrl}?sections=${sectionIds}`;
                const response = await fetch(url);
                if (!response.ok) {
                  throw new Error(`Sections fetch failed: ${response.status}`);
                }
                const data = await response.json();
                sections.forEach((section) => {
                  if (!section.selector || !section.section) return;
                  const elementToReplace = document.querySelector(section.selector);
                  const sectionHtml = data[section.section];
                  if (elementToReplace && sectionHtml) {
                    try {
                      const parsedHtml = new DOMParser()
                        .parseFromString(sectionHtml, 'text/html')
                        .querySelector(section.selector);
                      if (parsedHtml) {
                        elementToReplace.innerHTML = parsedHtml.innerHTML;
                      }
                    } catch (parseErr) {
                      console.error('[Marvya Rewards] Failed to parse section HTML:', parseErr);
                    }
                  }
                });
                return;
              }
            }
          } catch (err) {
            console.error('[Marvya Rewards] Section refresh failed:', err);
          }
        }
        try {
          const rootUrl = window.Shopify?.routes?.root || '/';
          const response = await fetch(`${rootUrl}?sections=cart-drawer`);
          if (response.ok) {
            const sections = await response.json();
            if (sections['cart-drawer']) {
              const parser = new DOMParser();
              const doc = parser.parseFromString(sections['cart-drawer'], 'text/html');
              const newCartDrawerContent = doc.querySelector('.drawer__inner');
              const currentDrawerInner = cartDrawer.querySelector('.drawer__inner');
              if (newCartDrawerContent && currentDrawerInner) {
                currentDrawerInner.innerHTML = newCartDrawerContent.innerHTML;
                return;
              }
            }
          }
        } catch (err) {
          console.error('[Marvya Rewards] Direct HTML refresh failed:', err);
        }
        try {
          const events = [
            new CustomEvent('cart:refresh', { bubbles: true }),
            new CustomEvent('cart:updated', { bubbles: true }),
            new CustomEvent('shopify:cart:updated', { bubbles: true }),
          ];
          events.forEach((event) => document.dispatchEvent(event));
          cartDrawer.dispatchEvent(new CustomEvent('refresh', { bubbles: true }));
          return;
        } catch (err) {
          console.error('[Marvya Rewards] Event dispatch failed:', err);
        }
      }
      try {
        const fallbackEvents = [
          'cart:refresh',
          'cart:updated',
          'cart:change',
          'theme:cart:change',
          'shopify:cart:update',
        ];
        fallbackEvents.forEach((eventName) => {
          document.dispatchEvent(new CustomEvent(eventName, { bubbles: true }));
        });
      } catch (err) {
        console.error('[Marvya Rewards] Fallback events failed:', err);
      }
    }
    function setupEventListeners() {
      const cartUpdateEvents = [
        'cart:updated',
        'cart:refresh',
        'cart:change',
        'theme:cart:change',
        'shopify:cart:update',
      ];
      cartUpdateEvents.forEach((eventName) => {
        document.addEventListener(eventName, () => {
          setTimeout(ensurePlaceholderAndRefresh, 300);
        });
      });
      const drawerOpenEvents = [
        'cart-drawer:open',
        'cart:open',
        'drawer:open',
        'cart-drawer:opened',
        'shopify:cart:open',
      ];
      drawerOpenEvents.forEach((eventName) => {
        document.addEventListener(eventName, () => {
          setTimeout(() => ensurePlaceholderAndRefresh(0), 200);
        });
      });
      const cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer) {
        const drawerObserver = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
              const isActive =
                cartDrawer.classList.contains('active') ||
                cartDrawer.classList.contains('is-open') ||
                cartDrawer.classList.contains('open');
              if (isActive) {
                setTimeout(() => ensurePlaceholderAndRefresh(0), 200);
              }
            }
          });
        });
        drawerObserver.observe(cartDrawer, {
          attributes: true,
          attributeFilter: ['class'],
        });
      }
      document.addEventListener('shopify:section:load', (e) => {
        if (e.detail?.sectionId?.includes('cart')) {
          setTimeout(ensurePlaceholderAndRefresh, 200);
        }
      });
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.removedNodes.forEach((node) => {
            if (node.id === 'marvya-rewards-placeholder') {
              if (node.getAttribute('data-shop')) {
                cachedShop = node.getAttribute('data-shop');
              }
              const newPlaceholder = recreatePlaceholder();
              if (newPlaceholder) {
                setTimeout(() => loadRewards(!cachedContent), 100);
              }
            }
          });
        });
      });
      observer.observe(document.body, {
        childList: true,
        subtree: true,
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
