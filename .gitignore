# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.dll

# Virtual environments
.venv/
venv/
env/
ENV/

# Editors/IDEs
.vscode/
.idea/
*.iml

# OS junk
.DS_Store
Thumbs.db

# Logs & temporary files
*.log
*.tmp
*.swp
*.swo

# Local configuration / secrets
.env
.env.*.local
*.local.json

# Model weights (Whisper, large files; don't version control)
models/
# If you need to keep documentation in models/, whitelist it:
# !models/README.md

# ComfyUI workflows
.workflows/text2img_any45.json
.workflows/text2img_ema15.json
.workflows/text2img_rV15.json

# Generated outputs (images, artifacts)
outputs/
# If you want to keep sample outputs tracked, whitelist a README:
# !outputs/README.md

# Static build artifacts (only if you have toolchains that build into static/)
static/**/dist/
static/**/build/
static/**/.cache/

# Test and coverage caches
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.cache/

# Jupyter checkpoints (if notebooks are ever used)
.ipynb_checkpoints/

# Dependency managers (optional)
poetry.lock
Pipfile.lock

# Packaging/build artifacts
build/
dist/
*.egg-info/

# Plans
plan.odt
