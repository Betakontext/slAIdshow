# ===== Audio =====
APP_AUDIO_DEVICE=0
APP_SAMPLE_RATE=48000
APP_FRAME_DURATION_MS=20
# Erzwinge ALSA "hw:X,Y" nur wenn nötig (0 bevorzugt pulse/default)
APP_FORCE_HW_DEVICE=0

# ===== VAD =====
# 1 = VAD aus, 0 = VAD an
APP_DISABLE_VAD=1
APP_VAD_AGGRESSIVENESS=0
# Etwas konservativer Schwellenwert; bei leiser Sprache ggf. auf 0.012 senken
APP_RMS_VAD_THRESHOLD=0.12

# ===== Snapshot/Buffer =====
# Alle X Sekunden ein Snapshot/Transkript (nach schnellem ersten Snapshot)
APP_SNAPSHOT_SEC=6.0
# Rolling-Buffer-Länge in Sekunden (Standard 12.0); optional
APP_ROLLING_BUFFER_SEC=12.0

# ===== Whisper =====
APP_WHISPER_MODEL_PATH=/home/mc/Documents/Arbeiten/0000_DEV/Python/speechtoimage_ai/models/ggml-base.bin
APP_WHISPER_LANGUAGE=de
APP_WHISPER_THREADS=4
APP_WHISPER_TEMPERATURE=0.0

# ===== Ollama =====
APP_OLLAMA_HOST=127.0.0.1
APP_OLLAMA_PORT=11434
APP_OLLAMA_MODEL=glm-4.7:cloud
APP_OLLAMA_TEMPERATURE=0.2
APP_OLLAMA_TIMEOUT_SEC=60
# LLM-Intervalle (Anforderung: 10s)
APP_LLM_INTERVAL_SEC=10

# ===== ComfyUI (vorbereitet, derzeit deaktiviert) =====
APP_DISABLE_COMFYUI=1
APP_COMFY_HOST=127.0.0.1
APP_COMFY_PORT=8188

# ===== Ausgabeordner =====
APP_OUTPUT_DIR=./outputs/images
