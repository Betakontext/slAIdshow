
# =========================
# Base settings (audio, VAD, segmentation)
# =========================
APP_AUDIO_DEVICE=pipewire                   # Optional: exact input device name; leave empty to auto-pick
APP_SAMPLE_RATE=48000                       # Audio sample rate (Hz)
APP_FRAME_DURATION_MS=40                    # Audio frame size for processing (ms)
APP_STREAM_LATENCY_SEC=0.12                 # Target input stream latency (s)

# Voice Activity Detection (VAD)
APP_DISABLE_VAD=1                           # 1 = disable VAD (always speech), 0 = enable VAD
APP_RMS_VAD_THRESHOLD=0.02                  # RMS threshold for simple VAD (higher = stricter)

# Snapshot / segmentation (when to run Whisper)
APP_SNAPSHOT_SEC=4.0                        # Snapshot window to run Whisper on partial audio (s)
APP_MIN_BUF_SEC=0.8                         # Minimum buffered audio before first transcription (s)
APP_MAX_SILENCE_MS=1500                     # Endpointing: max silence to close a segment (ms)
APP_MAX_SEGMENT_SEC=15.0                    # Hard cap for a segment length (s)
APP_FIRST_SNAPSHOT_DEADLINE_SEC=0.8         # Earliest time to attempt first snapshot (s)

# Text filtering
APP_TEXT_MIN_CHARS=6
APP_TEXT_MIN_WORDS=2
APP_FORCE_MEANINGFUL_CHECK=1                # 1 = drop too-short or filler utterances

# Context buffer (for LLM prompt optimization)
APP_CONTEXT_MAX_SEGMENTS=5
APP_CONTEXT_MAX_CHARS=480

# =========================
# Whisper (pywhispercpp)
# =========================
APP_WHISPER_MODEL_PATH=./models/ggml-base.bin
APP_WHISPER_LANGUAGE=de
APP_WHISPER_THREADS=2
APP_WHISPER_TEMPERATURE=0.0
APP_WHISPER_MIN_SEC=0.35
APP_WHISPER_MIN_PEAK=0.0015

# =========================
# Ollama (local REST endpoint used by the app)
# =========================
# PROFILE A: Purely local (privacy-friendly)
# APP_OLLAMA_MODEL=llama3.2:latest
# Alternative local models:
# APP_OLLAMA_MODEL=phi3:mini
# APP_OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_0

# PROFILE B: Cloud LLM via Ollama (prompts may leave the machine via Ollama)
# (Enable only if explicitly desired)
APP_OLLAMA_MODEL=phi3:mini

APP_OLLAMA_HOST=127.0.0.1
APP_OLLAMA_PORT=11434
APP_OLLAMA_TEMPERATURE=0.2
APP_OLLAMA_NUM_CTX=3072
APP_OLLAMA_NUM_PREDICT=640
APP_OLLAMA_TOP_K=40
APP_OLLAMA_TOP_P=0.9
APP_OLLAMA_REPEAT_PENALTY=1.1
APP_OLLAMA_TIMEOUT_SEC=90
APP_OLLAMA_MAX_RETRIES=4
APP_OLLAMA_RETRY_BASE_DELAY=0.8
APP_LLM_INTERVAL_SEC=10.0
APP_OLLAMA_DISABLE=0
APP_OLLAMA_WARMUP_ENABLE=1
APP_OLLAMA_WARMUP_TIMEOUT_SEC=45
APP_OLLAMA_WARMUP_RETRY_DELAY=1.2

# Neutral system prompt for image prompt optimization
APP_OLLAMA_SYS_PROMPT=You are an expert at image prompting. Produce concise, vivid prompts for image generators (e.g., SDXL) without meta-comments. Prefer concrete subjects, style, lighting, composition, and key attributes. Keep it short (1–2 sentences). Answer in the user's language.

# =========================
# Image Backend switch (UI can change this at runtime)
# =========================
# Choose exactly one backend: comfyui (local, default) or pollinations (cloud).
IMAGE_BACKEND=comfyui
# IMAGE_BACKEND=pollinations

# Allow cloud image backends only if set to 1
ALLOW_CLOUD_IMAGE_BACKEND=0

# Persisted output directory (served via /static)
APP_OUTPUT_DIR=./outputs/images

# Optional default image size (UI can override per request)
# APP_IMAGE_WIDTH=512
# APP_IMAGE_HEIGHT=512

# =========================
# ComfyUI (local)
# =========================
# Used only when IMAGE_BACKEND=comfyui
APP_DISABLE_COMFYUI=0                      # 0 = enable ComfyUI integration, 1 = disable
APP_COMFY_SAMPLER=euler
APP_COMFY_HOST=127.0.0.1
APP_COMFY_PORT=8188
APP_COMFY_WORKFLOW=./workflows/text2img_any45.json
APP_COMFY_TIMEOUT_SEC=120
APP_COMFY_WIDTH=128
APP_COMFY_HEIGHT=128

# Optional: where ComfyUI writes images (fallback for downloads)
APP_COMFY_OUTPUT_DIR=/home/cm/Dokumente/Arbeiten/0000_DEV/ComfyUI/output/


# =========================
# Pollinations (cloud)
# =========================
# Used only when IMAGE_BACKEND=pollinations AND ALLOW_CLOUD_IMAGE_BACKEND=1
POLLINATIONS_API_BASE=https://gen.pollinations.ai
POLLINATIONS_SECRET=sk_iFIDaZ4xsL0v4cUwV2JMDBxnEk5dfm9l   # Do NOT commit to repos
POLLINATIONS_MODEL=flux
POLLINATIONS_NOLOGO=1
POLLINATIONS_SEED=1234
POLLINATIONS_USE_V1=1
# Set either SIZE or WIDTH/HEIGHT:
# POLLINATIONS_SIZE=1024x1024
POLLINATIONS_WIDTH=1024
POLLINATIONS_HEIGHT=1024


