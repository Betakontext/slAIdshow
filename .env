# ===== Audio =====
APP_AUDIO_DEVICE=0
APP_SAMPLE_RATE=48000
APP_FRAME_DURATION_MS=20

# ===== VAD =====
# 1 = VAD komplett aus (kontinuierlich), 0 = VAD aktiv
APP_DISABLE_VAD=1
APP_VAD_AGGRESSIVENESS=0
APP_RMS_VAD_THRESHOLD=0.012

# Alle X Sekunden ein Snapshot/Transkript
APP_SNAPSHOT_SEC=6.0

# ===== Whisper =====
APP_WHISPER_MODEL_PATH=/home/mc/Documents/Arbeiten/0000_DEV/Python/speechtoimage_ai/models/ggml-base.bin
APP_WHISPER_LANGUAGE=de
APP_WHISPER_THREADS=4
APP_WHISPER_TEMPERATURE=0.0

# ===== Ollama (optional) =====
APP_OLLAMA_HOST=127.0.0.1
APP_OLLAMA_PORT=11434
APP_OLLAMA_MODEL=phi3:mini
APP_OLLAMA_TEMPERATURE=0.2

# ===== ComfyUI (optional) =====
APP_COMFY_HOST=127.0.0.1
APP_COMFY_PORT=8188

# ===== Ausgabeordner =====
APP_OUTPUT_DIR=./outputs/images
