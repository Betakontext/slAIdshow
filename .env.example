
# =========================
# Server bind (keep local)
# =========================
APP_BIND_HOST=127.0.0.1
APP_BIND_PORT=8080

# =========================
# Audio / Stream / SSE
# =========================
APP_AUDIO_DEVICE=pipewire
APP_SAMPLE_RATE=48000
APP_FRAME_DURATION_MS=20
APP_STREAM_LATENCY_SEC=0.12
APP_SSE_TICK_SEC=60.0

# =========================
# VAD & segmentation
# =========================
APP_DISABLE_VAD=1
APP_RMS_VAD_THRESHOLD=0.015
APP_SNAPSHOT_SEC=2.5
APP_MIN_BUF_SEC=0.35
APP_MAX_SILENCE_MS=700
APP_MAX_SEGMENT_SEC=12.0
APP_FIRST_SNAPSHOT_DEADLINE_SEC=1.2

# =========================
# Text filter
# =========================
APP_TEXT_MIN_CHARS=3
APP_TEXT_MIN_WORDS=1
APP_FORCE_MEANINGFUL_CHECK=0

# =========================
# Whisper (pywhispercpp)
# =========================
APP_WHISPER_MODEL_PATH=./models/ggml-base.bin
APP_WHISPER_LANGUAGE=de
APP_WHISPER_THREADS=2
APP_WHISPER_TEMPERATURE=0.0
APP_WHISPER_MIN_SEC=0.35
APP_WHISPER_MIN_PEAK=0.0009

# =========================
# Context for LLM (Ollama)
# =========================
APP_CONTEXT_MAX_SEGMENTS=5
APP_CONTEXT_MAX_CHARS=480

# =========================
# Ollama (local only)
# =========================
# Vision descriptors (optional)
FEATURE_STYLE_REF_VISION_CLOUD=1
APP_OLLAMA_VISION_MODEL=gemma3:27b-cloud
APP_OLLAMA_HOST_FOR_VISION=${APP_OLLAMA_HOST_URL}

# Text model
APP_OLLAMA_MODEL=gemma3:1b
APP_OLLAMA_HOST=http://127.0.0.1:11434
APP_OLLAMA_PORT=11434
APP_OLLAMA_HOST_URL=http://127.0.0.1:11434
APP_OLLAMA_TEMPERATURE=0.2
APP_OLLAMA_NUM_CTX=3072
APP_OLLAMA_NUM_PREDICT=640
APP_OLLAMA_TOP_K=40
APP_OLLAMA_TOP_P=0.9
APP_OLLAMA_REPEAT_PENALTY=1.1
APP_OLLAMA_TIMEOUT_SEC=90
APP_OLLAMA_MAX_RETRIES=4
APP_OLLAMA_RETRY_BASE_DELAY=0.8
APP_LLM_INTERVAL_SEC=10.0
APP_OLLAMA_DISABLE=0
# Note: warmup can be auto-disabled in code when IMAGE_BACKEND=pollinations
APP_OLLAMA_WARMUP_ENABLE=1
APP_OLLAMA_WARMUP_PROMPT=Say hello in German.
APP_OLLAMA_GRACE_SEC=10.0
APP_OLLAMA_WARMUP_RETRY_DELAY=1.2
APP_OLLAMA_SYS_PROMPT=You are a precise prompt designer for image generators. Produce short, clear German image prompts without meta comments.

# =========================
# Proxy bypass for local/private targets (LAN + WireGuard)
# =========================
NO_PROXY=localhost,127.0.0.1,192.168.188.24,192.168.188.0/24,10.8.0.0/24

# =========================
# Style / references
# =========================
APP_STYLE_CFG_DIR=./outputs/config
APP_STYLE_REF_DIR=./outputs/style_refs
APP_REF_HOST=
APP_REF_TTL_SEC=180
APP_REF_SECRET=
APP_REFERENCE_DENOISE_ENABLE=1
STYLE_REFERENCE_LEAN_PROMPT=1

# =========================
# Outputs
# =========================
APP_OUTPUT_DIR=./outputs/images

# =========================
# Backend selection (UI-driven)
# comfyui        -> LocalComfy (127.0.0.1)
# comfyui_remote -> RemoteComfy (LAN/WG from presets below)
# pollinations   -> Cloud
# =========================
APP_IMAGE_BACKEND=comfyui
IMAGE_BACKEND=${APP_IMAGE_BACKEND}
APP_IMAGE_BACKEND_DEFAULT=comfyui
BACKEND_CHOICES=comfyui,comfyui_remote,pollinations

# Unified canvas defaults
APP_IMAGE_WIDTH=768
APP_IMAGE_HEIGHT=768

# =========================
# ComfyUI - LOCAL preset (this machine)
# =========================
COMFY_LOCAL_HOST=127.0.0.1
COMFY_LOCAL_PORT=8188

# Default values used by LocalComfyBackend; will be overridden by remote preset at runtime when comfyui_remote is active
APP_COMFY_HOST=${COMFY_LOCAL_HOST}
APP_COMFY_PORT=${COMFY_LOCAL_PORT}
APP_COMFY_WORKFLOW=./workflows/text2img_SD15-FP16.json
APP_COMFY_STEPS=20
APP_COMFY_CFG=6.5
APP_COMFY_SAMPLER=euler
APP_COMFY_NEGATIVE=text, watermark, logo, low quality, blurry, bad anatomy
APP_COMFY_TIMEOUT_SEC=240
APP_COMFY_WIDTH=768
APP_COMFY_HEIGHT=768
# auto: local -> path, remote -> query (bridge enforces query for remote)
APP_COMFY_FORCE_VIEW_MODE=auto
APP_COMFY_UPLOAD_ENDPOINT=/upload/image
APP_COMFY_INPUT_DIR=./ComfyUI/input
APP_COMFY_OUTPUT_DIR=./ComfyUI/output
APP_COMFY_REF_MODE=file
APP_COMFY_NODE_POS=2
APP_COMFY_NODE_NEG=3
APP_COMFY_NODE_LATENT=4
APP_COMFY_NODE_KSAMPLER=5
APP_COMFY_NODE_REF_IMAGE=
APP_COMFY_KEY_REF_IMAGE_PATH=image
APP_COMFY_NODE_IPADAPTER=
APP_COMFY_KEY_REF_WEIGHT=weight
APP_COMFY_NODE_REF_URL=
APP_COMFY_KEY_REF_URL=url

# =========================
# ComfyUI - REMOTE preset (LAN or WireGuard)
# Adjust COMFY_REMOTE_HOST as needed:
#   - LAN: 192.168.188.24
#   - WireGuard: 10.8.0.2
# =========================
COMFY_REMOTE_HOST=192.168.188.24
COMFY_REMOTE_PORT=8188
# Alternative for WG:
# COMFY_REMOTE_HOST=10.8.0.2
# COMFY_REMOTE_PORT=8188

# Security policy for remote backends (allow LAN + WG)
APP_ALLOW_REMOTE_BACKENDS=1
STRICT_LOCAL_ONLY=0
APP_ALLOWED_SUBNETS=127.0.0.1/32,192.168.188.0/24,10.8.0.0/24
APP_COMFY_REMOTE_WHITELIST=127.0.0.1/32,192.168.188.0/24,10.8.0.0/24
# Allowlist for local LLM/Vision (Ollama)
ALLOW_LOCAL_LLM=1
APP_LOCAL_LLM_ALLOWLIST=127.0.0.1:11434

# =========================
# Pollinations (cloud) - used by image_backend.py
# IMPORTANT: Do not commit real secrets. Set locally/CI only.
# =========================
POLLINATIONS_API_BASE=https://get.pollinations.ai
POLLINATIONS_GEN_BASE=https://gen.pollinations.ai
POLLINATIONS_SECRET=
POLLINATIONS_MODEL=flux
POLLINATIONS_IMAGE_MODEL=${POLLINATIONS_MODEL}
POLLINATIONS_NOLOGO=1
POLLINATIONS_SEED=1234
POLLINATIONS_USE_V1=1
POLLINATIONS_SIZE=
POLLINATIONS_V1_IMAGES_EDITS_PATH=/v1/images/edits
POLLINATIONS_V1_IMAGES_EDITS_ENDPOINT=/v1/images/edits
POLLINATIONS_V1_IMAGES_GENERATIONS_ENDPOINT=/v1/images/generations
POLLINATIONS_UPLOAD_ENDPOINT=/upload
POLLINATIONS_WIDTH=1024
POLLINATIONS_HEIGHT=1024
POLLINATIONS_ENABLE_UPLOAD=1
FEATURE_POLLINATIONS_V1_EDITS=1
FEATURE_POLLINATIONS_USE_URL_MODE=1
POLLINATIONS_STYLE_SUFFIX=adopt the exact visual style, colors, and textures from the reference image; only transfer content-neutral style elements.
POLLINATIONS_TIMEOUT_SEC=120

ALLOW_CLOUD_IMAGE_BACKEND=1

# (Optional APP_* mirrors not used by code; keep only if other components rely on them)
# APP_POLLINATIONS_API_BASE=https://gen.pollinations.ai
# APP_POLLINATIONS_GEN_BASE=https://gen.pollinations.ai
# APP_POLLINATIONS_REF_MODE=auto
# APP_POLLINATIONS_ENABLED=true

# =========================
# HTTP client tuning
# =========================
APP_HTTP_TIMEOUT_SEC=15.0
APP_HTTP_RETRIES=5
APP_HTTP_RETRY_BACKOFF_SEC=0.5

# =========================
# Debug
# =========================
APP_DEBUG=0
APP_IMAGE_BACKEND_DEBUG=0
APP_DISABLE_COMFYUI=0
APP_COMFY_BRIDGE_DEBUG=1

