# =========================
# Server-Bind (lokal halten)
# =========================
APP_BIND_HOST=127.0.0.1
APP_BIND_PORT=8080

# =========================
# Audio / Stream / SSE
# =========================
APP_AUDIO_DEVICE=                       # optional exakter Gerätename, leer = auto
APP_SAMPLE_RATE=48000
APP_FRAME_DURATION_MS=20
APP_STREAM_LATENCY_SEC=0.12
APP_SSE_TICK_SEC=1.0

# =========================
# VAD & Segmentierung
# =========================
APP_DISABLE_VAD=1
APP_RMS_VAD_THRESHOLD=0.015
APP_SNAPSHOT_SEC=2.5
APP_MIN_BUF_SEC=0.35
APP_MAX_SILENCE_MS=700
APP_MAX_SEGMENT_SEC=12.0
APP_FIRST_SNAPSHOT_DEADLINE_SEC=1.2

# =========================
# Textfilter (Frontend/Trigger)
# =========================
APP_TEXT_MIN_CHARS=3
APP_TEXT_MIN_WORDS=1
APP_FORCE_MEANINGFUL_CHECK=0

# =========================
# Whisper (pywhispercpp)
# =========================
APP_WHISPER_MODEL_PATH=./models/ggml-base.bin
APP_WHISPER_LANGUAGE=de
APP_WHISPER_THREADS=2
APP_WHISPER_TEMPERATURE=0.0
APP_WHISPER_MIN_SEC=0.35
APP_WHISPER_MIN_PEAK=0.0009

# =========================
# Kontext für LLM
# =========================
APP_CONTEXT_MAX_SEGMENTS=5
APP_CONTEXT_MAX_CHARS=480

# =========================
# Ollama (STRICT lokal)
# =========================
APP_OLLAMA_HOST=127.0.0.1
APP_OLLAMA_PORT=11434
APP_OLLAMA_MODEL=gemma3:1b
APP_OLLAMA_TEMPERATURE=0.2
APP_OLLAMA_NUM_CTX=3072
APP_OLLAMA_NUM_PREDICT=640
APP_OLLAMA_TOP_K=40
APP_OLLAMA_TOP_P=0.9
APP_OLLAMA_REPEAT_PENALTY=1.1
APP_OLLAMA_TIMEOUT_SEC=90
APP_OLLAMA_MAX_RETRIES=4
APP_OLLAMA_RETRY_BASE_DELAY=0.8
APP_LLM_INTERVAL_SEC=10.0
APP_OLLAMA_DISABLE=0

# Warmup
APP_OLLAMA_WARMUP_ENABLE=1
APP_OLLAMA_WARMUP_PROMPT=Sag Hallo auf Deutsch.
APP_OLLAMA_GRACE_SEC=10.0
APP_OLLAMA_WARMUP_RETRY_DELAY=1.2

# Systemprompt (deutsch, kurz)
APP_OLLAMA_SYS_PROMPT=Du bist ein präziser Prompt-Designer für Bildgeneratoren. Erzeuge kurze, klare, fotografische oder illustrative Bild-Prompts, ohne Meta-Kommentare, in Deutsch.

# =========================
# Style-Konfig / Referenzen
# =========================
APP_STYLE_CFG_DIR=./outputs/config
APP_STYLE_REF_DIR=./outputs/style_refs

# Optional: Signierte lokale/LAN-URLs für Referenzbilder (nur wenn URL-Modus benötigt)
APP_REF_HOST=                             # z.B. http://127.0.0.1:8080 (leer = auto)
APP_REF_TTL_SEC=180
APP_REF_SECRET=                           # zwingend setzen, wenn APP_REF_HOST genutzt wird

# =========================
# Ausgabeordner
# =========================
APP_OUTPUT_DIR=./outputs/images

# =========================
# Image-Backends
# =========================
# Laufzeit-Backend (wird auch via API umgeschaltet)
# Erlaubt: comfyui | pollinations
IMAGE_BACKEND=comfyui

# Global UI-Default-Größen (werden im STATE vorinitialisiert)
APP_IMAGE_WIDTH=512
APP_IMAGE_HEIGHT=512

# --- ComfyUI gemeinsame Settings ---
# Aktuelles Ziel (Host/Port); "local" vs "remote" Umschaltung erfolgt via /api/settings/comfy_target
APP_COMFY_HOST=127.0.0.1
APP_COMFY_PORT=8188

# Defaultgrößen für ComfyUI (klein, schnell)
APP_COMFY_WIDTH=128
APP_COMFY_HEIGHT=128

# Remote Backends erlauben? (nur LAN/VPN)
APP_ALLOW_REMOTE_BACKENDS=1
# Whitelist für Remote-Hosts (CIDR oder Host/IP, komma-separiert)
APP_COMFY_REMOTE_WHITELIST=127.0.0.1/32,192.168.188.0/24

# ComfyUI global deaktivieren? (UI blendet Workflow-Selector aus, Generation via Comfy bleibt möglich wenn Backend aktiv)
APP_DISABLE_COMFYUI=0

# Optional: Arbeitsverzeichnis für Workflows (wird automatisch angelegt)
WORKFLOWS_DIR=./workflows

# =========================
# Pollinations (Cloud) – optional
# =========================
# Cloud-Backends global erlauben (muss 1 sein, um auf pollinations zu schalten)
ALLOW_CLOUD_IMAGE_BACKEND=1

# API-Basis und Secret
POLLINATIONS_API_BASE=https://gen.pollinations.ai
POLLINATIONS_SECRET=                         # sk_xxx – MUSS gesetzt sein, sonst blockt /api/settings/image_backend

# Modell/Parameter
POLLINATIONS_MODEL=flux
POLLINATIONS_NOLOGO=1
POLLINATIONS_SEED=1234
POLLINATIONS_USE_V1=1

# Defaultgrößen für Pollinations (größer, qualitativ)
POLLINATIONS_WIDTH=1024
POLLINATIONS_HEIGHT=1024

# Referenz-Übertragungsmodus: auto | multipart | url
APP_POLLINATIONS_REF_MODE=auto

# =========================
# HTTP-Client Tuning
# =========================
APP_HTTP_TIMEOUT_SEC=1.0
APP_HTTP_RETRIES=3
APP_HTTP_RETRY_BACKOFF_SEC=0.25

# =========================
# Debug
# =========================
APP_DEBUG=0
