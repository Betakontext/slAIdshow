# =========================
# Base settings (local & cloud)
# =========================
APP_AUDIO_DEVICE=pipewire              # Optional: exact input device name; leave empty to auto-pick
APP_SAMPLE_RATE=48000                  # Audio sample rate (Hz)
APP_FRAME_DURATION_MS=20               # Audio frame size for processing (ms)
APP_STREAM_LATENCY_SEC=0.12            # Input stream latency target (s)
APP_SSE_TICK_SEC=30.0                  # SSE heartbeat interval (s)

# VAD (Voice Activity Detection)
APP_DISABLE_VAD=1                      # 1 = disable VAD (always treat audio as speech), 0 = enable VAD
APP_USE_WEBRTC_VAD=0                   # 1 = use webrtcvad if installed; 0 = use simple RMS-VAD
APP_VAD_AGGRESSIVENESS=0               # webrtcvad aggressiveness [0..3] (0 = least aggressive)
APP_RMS_VAD_THRESHOLD=0.02             # RMS threshold for simple VAD (higher = more strict)
# APP_RMS_VAD_THRESHOLD=0.015          # Alternative, slightly looser threshold

# Snapshot / segmentation (when to run transcription)
APP_SNAPSHOT_SEC=4.0                   # Snapshot window to run Whisper on partial audio (s)
APP_MIN_BUF_SEC=0.8                    # Minimum buffered audio before first transcription (s)
APP_MAX_SILENCE_MS=1500                # Endpointing: max silence to close a segment (ms)
APP_MAX_SEGMENT_SEC=15.0               # Hard cap for a segment length (s)
APP_FIRST_SNAPSHOT_DEADLINE_SEC=0.8    # Earliest time to attempt first snapshot (s)

# Aggressive snapshot, shorter min buffer (uncomment to try)
# APP_SNAPSHOT_SEC=2.5
# APP_MIN_BUF_SEC=0.35
# APP_MAX_SILENCE_MS=700
# APP_MAX_SEGMENT_SEC=12.0
# APP_FIRST_SNAPSHOT_DEADLINE_SEC=0.7

# Frontend text filter (display-only; LLM triggering is separate below)
APP_TEXT_MIN_CHARS=3
APP_TEXT_MIN_WORDS=1
APP_FORCE_MEANINGFUL_CHECK=false


# =========================
# Transscriptions via Whisper
# =========================

# Whisper (pywhispercpp)
# For German, use ggml-base.bin; for weak CPUs use ggml-tiny.bin
APP_WHISPER_MODEL_PATH=./models/ggml-base.bin
APP_WHISPER_LANGUAGE=de               # Language hint; set "" for auto-detect (may raise latency)
APP_WHISPER_THREADS=2                  # Threads for whisper.cpp (keep low to protect CPU)
APP_WHISPER_TEMPERATURE=0.0            # Whisper decoding temperature (0.0 = deterministic)

# Whisper gating (minimum content/peak)
# APP_WHISPER_MIN_SEC=0.6              # Ensure at least this much audio (pads if shorter)
# APP_WHISPER_MIN_PEAK=0.004           # Min absolute peak to avoid transcribing near-silence
APP_WHISPER_MIN_SEC=0.35
APP_WHISPER_MIN_PEAK=0.0015

# Text filtering for triggering (pipeline gate)
APP_TEXT_MIN_CHARS=6                   # Minimal chars to consider text meaningful
APP_TEXT_MIN_WORDS=2                   # Minimal words to consider text meaningful
APP_FORCE_MEANINGFUL_CHECK=1           # 1 = drop too-short/empty filler utterances


# =========================
# Image prompts via Ollama
# =========================
# Rolling context for LLM prompt optimization
APP_CONTEXT_MAX_SEGMENTS=5             # Keep last N transcripts in rolling context
APP_CONTEXT_MAX_CHARS=480              # Cap total context characters

# Ollama (local REST endpoint used by the app; KEEP STRICTLY LOCAL)
APP_OLLAMA_HOST=127.0.0.1              # Hard safety: localhost only in this app
APP_OLLAMA_PORT=11434
APP_OLLAMA_TEMPERATURE=0.2             # Default generation temperature
APP_OLLAMA_NUM_CTX=3072                # Context window (tokens) if supported
APP_OLLAMA_NUM_PREDICT=640             # Max tokens to generate (latency cap)
APP_OLLAMA_TOP_K=40
APP_OLLAMA_TOP_P=0.9
APP_OLLAMA_REPEAT_PENALTY=1.1
APP_OLLAMA_TIMEOUT_SEC=90              # Read timeout for Ollama requests (s)
APP_OLLAMA_MAX_RETRIES=4               # Retry attempts on transient errors
APP_OLLAMA_RETRY_BASE_DELAY=0.8        # Initial backoff delay (s)
APP_LLM_INTERVAL_SEC=10.0              # Min interval between LLM calls (rate limiting)
APP_OLLAMA_DISABLE=0                   # 1 = disable LLM stage (audio-only debugging)
APP_OLLAMA_WARMUP_ENABLE=1             # 1 = run a short warmup call at startup
APP_OLLAMA_WARMUP_TIMEOUT_SEC=45       # Warmup request timeout (s)
APP_OLLAMA_WARMUP_RETRY_DELAY=1.2      # Delay between warmup retries (s)

# Neutral system prompt for image prompt optimization (concise, no meta)
APP_OLLAMA_SYS_PROMPT=Du bist Expertin/Experte für Bild-Prompting. Formuliere prägnante, anschauliche Prompts für Bildgeneratoren (z. B. SDXL), ohne Meta-Kommentare. Bevorzuge konkrete Motive, Stil, Licht, Komposition und Schlüsselattribute. Halte die Antwort kurz (1–2 Sätze). Antworte in der Sprache des Nutzers.

# PROFILE A: Purely local (privacy-friendly)
# Choose exactly one light model to reduce CPU load:
APP_OLLAMA_MODEL=gemma3:1b
# APP_OLLAMA_MODEL=phi3:mini
# APP_OLLAMA_MODEL=llama3.2:latest
# APP_OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_0

# PROFILE B: Cloud LLM via Ollama (prompts may leave your machine)
# APP_OLLAMA_MODEL=glm-4.7:cloud

# =========================
# Style analysis via Ollama cloud and local style engine
# =========================
APP_OLLAMA_VISION_MODEL=gemma3:27b-cloud
APP_ALLOW_REMOTE_VISION=1
FEATURE_OLLAMA_VISION_DEFAULT=1
# FEATURE_LOCAL_STYLE_ANALYSIS_FORCE_ON=1 #lokale Analyse immer aktiviert
# Style caps (token limits)
STYLE_ENGINE_MAX_TOKENS_STYLE_TEXT=40
STYLE_ENGINE_MAX_TOKENS_VISION=24
STYLE_ENGINE_MAX_TOKENS_DESCRIPTORS=12
STYLE_ENGINE_MAX_TOKENS_FINAL=40

# =========================
# Image generation via ComfyUI (local) or Pollinations (cloud)
# =========================

# Global image size defaults (apply to all backends if UI does not send width/height)
IMAGE_BACKEND=comfyui
APP_IMAGE_WIDTH=1280
APP_IMAGE_HEIGHT=720

# LAN
# Allow image backends on non-localhost (needed to reach ComfyUI on another LAN device)
APP_ALLOW_REMOTE_BACKENDS=1
# Start ComfyUI on the host PC with: python main.py --listen 0.0.0.0 --port 8188
APP_COMFY_HOST=127.0.0.1          # 127.0.0.1 for local service on the same device | LAN IPv4 (f.e. 198.765.432.10 ) of the other device in the same network ComfyUI is running on
APP_COMFY_PORT=8188
APP_COMFY_FALLBACK_HOSTS=192.168.188.24
APP_ALLOWED_SUBNETS=192.168.188.0/24
AUTO_DISCOVERY_ENABLE=1
AUTO_DISCOVERY_SUBNETS=192.168.188.0/24

# Cloud / remote
ALLOW_CLOUD_IMAGE_BACKEND=0            # Allow switching to cloud backends from UI (pollinations)
APP_ALLOW_REMOTE_BACKENDS=1            # Explicitly allow non-local image backends (e.g., LAN ComfyUI)

# Pollinations (cloud image backend; only used if switched to)
POLLINATIONS_API_BASE=https://gen.pollinations.ai
POLLINATIONS_SECRET=  # Your sk_*** Pollinations secret
POLLINATIONS_MODEL=flux
POLLINATIONS_NOLOGO=1
POLLINATIONS_SEED=1234
POLLINATIONS_USE_V1=1                  # 1 = use v1 endpoint, 0 = legacy GET
# width/height below apply
POLLINATIONS_WIDTH=
POLLINATIONS_HEIGHT=
POLLINATIONS_INLINE_NEG=1

# ComfyUI (image generation on same or on another device in the same network)
# Start ComfyUI on the host PC with: python main.py --listen 0.0.0.0 --port 8188
APP_COMFY_WORKFLOW=./workflows/text2img_SD15-FP16.json
APP_DISABLE_COMFYUI=0                  # 1 = skip image generation stage (LLM-only)
APP_COMFY_TIMEOUT_SEC=240
APP_COMFY_WIDTH=
APP_COMFY_HEIGHT=
# App HTTP server bind (optional: expose this app to LAN; keep Private network only)
APP_BIND_HOST=127.0.0.1                  # 127.0.0.1 = local only; 0.0.0.0 = all interfaces (LAN)
APP_BIND_PORT=8080

APP_COMFY_NODE_STYLE_POS=8
APP_COMFY_NODE_COND_COMBINE=9
APP_COMFY_STYLE_WEIGHT=1.8

# =========================
# Outputs
# =========================
APP_COMFY_OUTPUT_DIR=/home/cm/Dokumente/Arbeiten/0000_DEV/ComfyUI/output/  # Set here the /path to your local ComfyUI/outputs folder if used on the same machine, an not over local network (default)
# Outputs
APP_OUTPUT_DIR=./outputs/images        # Folder where images are saved/exposed via /static
